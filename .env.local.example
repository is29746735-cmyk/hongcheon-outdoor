# ─────────────────────────────────────────────────────────────
# 홍천 아웃도어 — 환경변수 예시 / 배포 체크리스트
# 로컬: 이 파일을 .env.local 로 복사해 값을 채우세요.
# 배포(Vercel): 같은 키들을 Vercel > Project > Settings > Environment Variables
#   에 등록하세요. (Vercel은 .env 통째로 붙여넣기 일괄 등록 지원)
#   ★ 환경변수 등록 후에는 반드시 "재배포(Redeploy)" 해야 적용됩니다.
# ─────────────────────────────────────────────────────────────

# ── 인증 / 소셜 로그인 (Auth.js · NextAuth v5) ────────────────
# 로그인 UI는 "소셜 키(하나 이상) + Turso DB"가 모두 설정돼야 나타납니다.
# 미설정 시 헤더 로그인 버튼이 숨겨지고 /api/auth 가 500이 됩니다.

# 세션 서명용 시크릿(필수). 생성: `npx auth secret` 또는 `openssl rand -base64 32`
AUTH_SECRET=

# 카카오 로그인 — https://developers.kakao.com > 내 앱
#  · [카카오 로그인 > Redirect URI] 에 등록:
#      http://localhost:3000/api/auth/callback/kakao
#      https://<프로덕션-도메인>/api/auth/callback/kakao
#  · [플랫폼 > Web > 사이트 도메인] 에 https://<프로덕션-도메인> 등록
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# 구글 로그인 — https://console.cloud.google.com > API/서비스 > 사용자 인증 정보 > OAuth 2.0 클라이언트
#  · [승인된 리디렉션 URI] 에 등록:
#      http://localhost:3000/api/auth/callback/google
#      https://<프로덕션-도메인>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 네이버 로그인 — https://developers.naver.com > 내 애플리케이션 > API 설정
#  · [Callback URL] 에 등록:
#      http://localhost:3000/api/auth/callback/naver
#      https://<프로덕션-도메인>/api/auth/callback/naver
AUTH_NAVER_ID=
AUTH_NAVER_SECRET=

# ── 데이터베이스 (Turso / libSQL) — 로그인 계정·저장·리뷰 저장 ──
# https://turso.tech 에서 DB 생성 후 URL/토큰 발급
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── 지도 ─────────────────────────────────────────────────────
# 카카오맵 JavaScript 키 (메인 동적 지도)
#  · developers.kakao.com > 앱 키 > JavaScript 키
#  · [플랫폼 > Web] 에 사용 도메인(http://localhost:3000, https://<프로덕션-도메인>) 등록
NEXT_PUBLIC_KAKAO_MAP_KEY=
# 네이버 클라우드 플랫폼(NCP) > Maps 에서 발급받은 Client ID
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# ── 사이트 절대 URL (메타데이터·SNS 공유 미리보기) ───────────
# 배포 도메인 입력. 예: https://hongcheon-outdoor-kv6c.vercel.app
# 미설정 시 http://localhost:3000 을 사용합니다.
NEXT_PUBLIC_SITE_URL=

# ── 날씨 (선택) ──────────────────────────────────────────────
# 기상청 AWS 1분 실측(현재 기온·강수). 미설정 시 Open-Meteo(무료, 15분)로 동작.
# data.go.kr > "기상청_AWS관측자료(1분)조회서비스" 활용신청 > 일반 인증키(Encoding)
KMA_SERVICE_KEY=
# 관측 지점번호 (기본 212 = 홍천)
KMA_AWS_STATION=212

# ── AI 사진 검열 (선택) ──────────────────────────────────────
# 경험담 업로드 사진을 OpenAI Moderation(omni-moderation-latest, 무료)으로 검사해
# 음란·폭력 등 부적절 이미지를 차단합니다. 미설정 시 검열을 건너뜁니다(사진 업로드는 그대로 동작).
# 키 발급: https://platform.openai.com/api-keys  (Create new secret key)
OPENAI_API_KEY=

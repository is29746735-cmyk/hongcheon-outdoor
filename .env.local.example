# 네이버 클라우드 플랫폼(NCP) > Maps 에서 발급받은 Client ID
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# 날씨(하늘상태·오늘 예보)는 Open-Meteo(무료, 키 불필요)를 사용합니다.
# 더 실시간에 가까운 "현재 기온·강수"는 아래 기상청 키로 켤 수 있습니다(선택).

# 카카오맵 JavaScript 키 (메인 화면 동적 지도용)
# 카카오 개발자센터(developers.kakao.com) > 내 앱 > 앱 키 > JavaScript 키
# 플랫폼 > Web 에 사용 도메인(http://localhost:3000, https://*.vercel.app)을 등록해야 합니다.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 사이트 절대 URL (메타데이터·SNS 공유 미리보기 기준)
# 배포 시 실제 도메인을 입력하세요. (예: https://hongcheon-outdoor.vercel.app)
# 미설정 시 http://localhost:3000 을 사용합니다.
NEXT_PUBLIC_SITE_URL=

# (선택) 기상청 AWS 1분 실측 — 현재 기온·강수를 거의 실시간으로 표시
# 공공데이터포털(data.go.kr) > "기상청_AWS관측자료(1분)조회서비스" 활용신청 후
# 마이페이지 > 일반 인증키(Encoding) 값을 넣으세요. (서버 전용, 브라우저 비노출)
# 비워두면 Open-Meteo(15분 간격)로 동작합니다.
KMA_SERVICE_KEY=
# 관측 지점번호 (기본 212 = 홍천)
KMA_AWS_STATION=212
